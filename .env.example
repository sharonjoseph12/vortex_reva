# ═══════════════════════════════════════════════
# VORTEX PROTOCOL — PRODUCTION TEMPLATE (.env.example)
# Copy to backend/.env and fill in your values.
# NEVER commit .env with real secrets.
# ═══════════════════════════════════════════════

# ── ALGORAND NETWORK (Testnet/Mainnet)
ALGORAND_ALGOD_URL=https://testnet-api.algonode.cloud
ALGORAND_ALGOD_TOKEN=
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud
ALGORAND_INDEXER_TOKEN=

# ── DATABASE & CACHE
# Supabase Postgres Connection (Transaction Mode)
DATABASE_URL=postgresql://postgres.[REF]:[PASSWORD]@db.[REF].supabase.co:5432/postgres
# Redis for Worker Coordination
REDIS_URL=redis://localhost:6379/0

# ── SUPABASE CLOUD
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[PUBLIC-ANON-KEY]
SUPABASE_SERVICE_ROLE_KEY=[PRIVATE-SERVICE-ROLE-KEY]

# ── AI JURY (The Judge Model)
GEMINI_API_KEY=[YOUR-GEMINI-KEY]

# ── ORACLE NODES (2-of-3 Consensus)
# In production, these should be separate keys in separate regions
ORACLE_1_MNEMONIC="word word ..."
ORACLE_2_MNEMONIC="word word ..."
ORACLE_3_MNEMONIC="word word ..."

# ── SECURITY & EXECUTION
DOCKER_IMAGE_NAME=vortex-sandbox-python:latest
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=[SECURE-64-CHAR-HEX]
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS & HOSTING
ENVIRONMENT=production
CORS_ORIGIN=https://your-domain.com
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# ── ERROR TRACKING
# Free tier: https://sentry.io
SENTRY_DSN=https://[KEY]@[ID].ingest.sentry.io/[PROJECT]

# ── DEMO MODE
VORTEX_DEMO_MODE=false
