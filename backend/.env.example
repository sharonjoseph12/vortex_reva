# ─── Algorand ───────────────────────────────────────────
# LocalNet
# ALGORAND_ALGOD_URL=http://127.0.0.1:4001
# ALGORAND_ALGOD_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
# ALGORAND_INDEXER_URL=http://127.0.0.1:8980
# TestNet (public node, no token needed)
ALGORAND_ALGOD_URL=https://testnet-api.algonode.cloud
ALGORAND_ALGOD_TOKEN=
ALGORAND_INDEXER_URL=https://testnet-idx.algonode.cloud

# ─── Oracle Mnemonics (3 independent nodes) ─────────────
ORACLE_1_MNEMONIC="word word ... word"
ORACLE_2_MNEMONIC="word word ... word"
ORACLE_3_MNEMONIC="word word ... word"

# ─── AI ─────────────────────────────────────────────────
GEMINI_API_KEY=AIza...

# ─── Auth ───────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-64-char-random-hex-string

# ─── Database ───────────────────────────────────────────
# Dev (SQLite)
DATABASE_URL=sqlite:///./vortex.db
# Production (PostgreSQL — e.g. Supabase connection string)
# DATABASE_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ─── Redis / Celery ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Supabase ───────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Docker (Solver Sandbox) ────────────────────────────
# Linux/Mac
# DOCKER_HOST=unix:///var/run/docker.sock
# Windows
# DOCKER_HOST=npipe:////./pipe/docker_engine

# ─── CORS & Hosting ─────────────────────────────────────
ENVIRONMENT=development
# Production: ENVIRONMENT=production
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
# Production: CORS_ORIGIN=https://your-domain.com
ALLOWED_HOSTS=*
# Production: ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# ─── Error Tracking ─────────────────────────────────────
# Get DSN from https://sentry.io (free tier available)
SENTRY_DSN=

# ─── Contract ───────────────────────────────────────────
# Auto-filled by deploy.py
APP_ID=
BUYER_MNEMONIC=

# ─── Demo Mode ──────────────────────────────────────────
# Set to false in production with real on-chain escrow
VORTEX_DEMO_MODE=true
